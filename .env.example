# ============================================================
# QuestLog — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# ── Database ─────────────────────────────────────────────────
# In Docker Compose, this is auto-set by the compose file.
# For local dev without Docker, point to your Postgres instance.
DATABASE_URL="postgresql://questlog:questlog_secret@localhost:5432/questlog?schema=public"

# Docker Compose Postgres credentials (used by docker-compose.yml)
POSTGRES_USER="questlog"
POSTGRES_PASSWORD="questlog_secret"
POSTGRES_DB="questlog"

# ── NextAuth ─────────────────────────────────────────────────
# NEXTAUTH_URL must be the canonical URL of your deployed app
NEXTAUTH_URL="https://your-domain.com"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret-string-at-least-32-chars"

# ── Google OAuth ─────────────────────────────────────────────
# Get from https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Steam API ────────────────────────────────────────────────
# Get from https://steamcommunity.com/dev/apikey
STEAM_API_KEY=""

# ── Tracker.gg ───────────────────────────────────────────────
# Get from https://tracker.gg/developers
TRACKER_API_KEY=""

# ── IGDB (Twitch) API ───────────────────────────────────────
# Get from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# ── App Port (optional) ─────────────────────────────────────
APP_PORT=3000
