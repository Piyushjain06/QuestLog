generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

// --- Core Entities ---

model User {
  id              String   @id @default(cuid())
  name            String?
  email           String?  @unique
  emailVerified   DateTime?
  password        String?
  image           String?
  bio             String?
  steamId         String?  @unique
  steamUsername   String?
  steamAvatarUrl  String?
  epicId          String?  @unique
  trackerPlatform String?
  trackerUsername String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  library         UserGameLibrary[]
  missionProgress UserMissionProgress[]
  sentRequests    Friendship[] @relation("SentRequests")
  receivedReqs    Friendship[] @relation("ReceivedRequests")
  achievements    UserAchievement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Game {
  id          String   @id @default(cuid())
  igdbId      String?  @unique
  title       String
  slug        String   @unique
  description String?
  coverUrl    String?
  bannerUrl   String?
  steamAppId  String?  @unique
  epicId      String?  @unique
  tgdbId      String?  @unique
  releaseDate DateTime? @db.Date // Use actual date types
  developer   String?
  publisher   String?
  rating      Float?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships replacing stringified JSON
  genres      GameGenre[]
  platforms   GamePlatform[]
  library     UserGameLibrary[]
  missions    Mission[]
  achievements Achievement[]

  @@index([igdbId])
  @@index([slug])
}

// --- Lookup & Junction Tables (Normalization) ---

model Genre {
  id    Int    @id @default(autoincrement())
  name  String @unique
  games GameGenre[]
}

model Platform {
  id    Int    @id @default(autoincrement())
  name  String @unique
  games GamePlatform[]
}

model GameGenre {
  gameId  String 
  genreId Int
  game    Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([gameId, genreId])
  @@index([genreId]) // Crucial for "Find games by genre"
}

model GamePlatform {
  gameId     String 
  platformId Int
  game       Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  platform   Platform   @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@id([gameId, platformId])
  @@index([platformId])
}

// --- User Action Entities ---

enum GameStatus {
  PLAYING
  COMPLETED
  DROPPED
  BACKLOG
}

model UserGameLibrary {
  userId      String     
  gameId      String     
  status      GameStatus @default(BACKLOG)
  playtimeHrs Float      @default(0)
  userRating  Float?
  favorite    Boolean    @default(false)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  details UserGameDetails?

  @@id([userId, gameId]) // Replaces CUID with composite primary key
  @@index([userId, status]) // Highly queried for user profiles
}

// Vertical Partitioning: Bulky/rarely updated data separated from volatile data
model UserGameDetails {
  userId       String 
  gameId       String 
  notes        String?
  achievements Json    @default("{}") // Native JSONB in Postgres
  
  library      UserGameLibrary @relation(fields: [userId, gameId], references: [userId, gameId], onDelete: Cascade)

  @@id([userId, gameId])
}

model Mission {
  id          String   @id @default(cuid())
  gameId      String   
  title       String
  description String?
  type        String   @default("MAIN") // MAIN, SIDE, ACHIEVEMENT, COLLECTIBLE
  difficulty  String?  // EASY, MEDIUM, HARD
  xpReward    Int      @default(0)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  game     Game                  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  progress UserMissionProgress[]
  
  @@index([gameId, orderIndex])
}

model UserMissionProgress {
  userId      String    
  missionId   String    
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@id([userId, missionId]) // Composite PK
  @@index([userId])
}

model Friendship {
  id         String   @id @default(cuid())
  senderId   String   
  receiverId String   
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Achievement {
  id          String   @id @default(cuid())
  gameId      String
  name        String   // Internal Steam API name (e.g. "ACH_WIN_ONE_GAME")
  displayName String
  description String?
  iconUrl     String?
  iconGrayUrl String?
  hidden      Boolean  @default(false)
  
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  users       UserAchievement[]

  @@unique([gameId, name])
  @@index([gameId])
}

model UserAchievement {
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId]) // Composite PK
  @@index([userId])
}
